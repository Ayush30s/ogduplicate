<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= exerciseObj.name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-image: url('https://img.freepik.com/premium-photo/gym-with-red-wall-black-bench-with-red-light-it_911201-3385.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
        }

        .overlay {
            background-color: rgba(0, 0, 0, 0.7); /* Slightly transparent black overlay */
        }
        /* Animation for hovering on buttons */
        .hover-grow {
            transition: transform 0.3s ease-in-out;
        }
        .hover-grow:hover {
            transform: scale(1.1);
        }

        /* Fade in animation */
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Add fade-in animation to content */
        .fade-in {
            animation: fadeIn 1s ease-in;
        }

        /* Flashing border effect */
        .flashing-border {
            animation: flashing 2s infinite;
        }

        @keyframes flashing {
            0% { border-color: red; }
            50% { border-color: white; }
            100% { border-color: red; }
        }
    </style>
</head>
<body class="bg-black text-white h-screen flex justify-center items-center">

    <div class="max-w-md mx-auto p-6 bg-gray-900 rounded-lg shadow-lg border-4 flashing-border fade-in">
        <!-- Title Section -->
        <h1 class="text-3xl font-bold text-center text-red-500 mb-6 animate-pulse"><%= exerciseObj.name %></h1>
   
        <!-- Exercise Info Section -->
        <div class="text-lg mb-4">
            <p><span class="font-semibold text-red-500">Sets:</span> <%= exerciseObj.sets %></p>
            <p><span class="font-semibold text-red-500">Reps:</span> <%= exerciseObj.reps %></p>
            <p><span class="font-semibold text-red-500">Focus:</span> <%= exerciseObj.focus %></p>
            <p class="mt-4"><%= exerciseObj.details %></p>
        </div>

        <!-- Video Section -->
        <div class="text-center mt-8">
            <a href="<%= exerciseObj.videoUrl %>" target="_blank" class="inline-block px-8 py-3 text-white bg-red-500 rounded-md hover:bg-red-600 transition-colors duration-300 hover-grow">
                Watch Video Tutorial
            </a>
        </div>
    </div>

</body>
</html>
