<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= exerciseObj.name %></title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-image: url('https://img.freepik.com/premium-photo/gym-with-red-wall-black-bench-with-red-light-it_911201-3385.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
        }

        .overlay {
            background-color: rgba(0, 0, 0, 0.8);
        }

        .hover-grow {
            transition: transform 0.3s ease-in-out, background-color 0.3s;
        }
        .hover-grow:hover {
            transform: scale(1.1);
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .fade-in {
            animation: fadeIn 1s ease-in;
        }

        .flashing-border {
            animation: flashing 2s infinite;
        }
        @keyframes flashing {
            0% { border-color: red; }
            50% { border-color: white; }
            100% { border-color: red; }
        }

        .text-shadow {
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);
        }
    </style>
</head>
<body class="bg-black text-white h-screen flex justify-center items-center">

    <div class="overlay w-full h-full absolute top-0 left-0"><%= locals.day %></div>

    <div class="relative z-10 max-w-lg mx-auto p-8 bg-gray-900 rounded-lg shadow-sm shadow-white">
        <!-- Title Section -->
        <h1 class="text-4xl font-extrabold text-center text-red-500 mb-6 animate-pulse text-shadow"><%= exerciseObj.name %></h1>
   
        <!-- Exercise Info Section -->
        <div class="text-lg mb-4 space-y-3">
            <p><span class="font-semibold text-red-500">Sets:</span> <%= exerciseObj.sets %></p>
            <p><span class="font-semibold text-red-500">Reps:</span> <%= exerciseObj.reps %></p>
            <p><span class="font-semibold text-red-500">Focus:</span> <%= exerciseObj.focus %></p>
            <p class="mt-4 leading-relaxed text-gray-300"><%= exerciseObj.details %></p>
        </div>

        <!-- Timer Section -->
        <div class="text-center mt-8">
            <form id="timer-form" action="/home/exercise/<%= exerciseObj.name %>/ <%= exerciseObj.focus %>/<%= locals.day %>" method="post">
                <!-- Input field for user to input time in minutes -->
                <input type="number" id="timer-input" name="time" class="w-24 px-4 py-2 text-black text-center rounded-md" placeholder="Minutes" min="1" required>
        
                <!-- Button to start the timer -->
                <button type="submit" id="start-timer" class="inline-block px-6 py-2 bg-red-500 text-white rounded-md hover:bg-red-600 hover-grow transition duration-300 ease-in-out mt-4">
                    Start Timer
                </button>
            </form>
        
            <!-- Timer display area -->
            <div id="timer-display" class="mt-4 text-3xl font-bold"></div>
        </div>
        
        <!-- Video Section -->
        <div class="text-center mt-8">
            <a href="<%= exerciseObj.videoUrl %>" target="_blank" class="inline-block px-10 py-4 text-lg font-bold text-white bg-red-500 rounded-md hover:bg-red-600 hover-grow transition duration-300 ease-in-out">
                Watch Video Tutorial
            </a>
        </div>
    </div>

    <script>
        const startButton = document.getElementById("start-timer");
        const timerDisplay = document.getElementById("timer-display");
        const timerInput = document.getElementById("timer-input");
        let timerInterval;

        startButton.addEventListener("click", function() {
            const userMinutes = parseInt(timerInput.value);
            if (isNaN(userMinutes) || userMinutes <= 0) {
                alert("Please enter a valid number of minutes.");
                return;
            }

            let timeRemaining = userMinutes * 60; // Convert minutes to seconds
            clearInterval(timerInterval); // Clear any previous timer

            // Start the countdown
            timerInterval = setInterval(() => {
                const minutes = Math.floor(timeRemaining / 60);
                const seconds = timeRemaining % 60;

                // Display the time
                timerDisplay.textContent = `${minutes}:${seconds < 10 ? "0" : ""}${seconds}`;

                // When the timer ends
                if (timeRemaining <= 0) {
                    clearInterval(timerInterval);
                    timerDisplay.textContent = "Time's up!";
                    alert("Your timer is complete!");
                }

                timeRemaining--;
            }, 1000);
        });
    </script>
</body>
</html>
