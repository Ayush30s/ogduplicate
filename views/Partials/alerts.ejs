
<% if (locals.msg) { %>
    <div id="alert" class="bg-red-100 border border-red-400 text-red-700 text-center px-4 py-3 relative mb-6" role="alert">
        <strong class="font-medium block sm:inline"><%= locals?.msg %></strong>
        <% if (locals?.subject) { %>
            <strong class="font-bold block sm:inline"><%= (locals?.subject).toUpperCase() %></strong>
        <% } %>
    </div>
<% } %>

