<!DOCTYPE html>
<html lang="en">
<%- include("./Partials/head") %>
<body class="bg-black flex items-center justify-center min-h-screen">
    <!-- Registration Form -->
    <div class="bg-white p-8 shadow-lg w-full max-w-lg rounded-lg">
        <h2 class="text-2xl font-bold text-red-600 text-center mb-6">Register to Join a Gym</h2>
        
        <form action="/register/user" method="POST" enctype="multipart/form-data"> <!-- Ensure enctype is set -->
            <!-- Name and Gender Inputs (Two fields in one line) -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <div>
                    <label for="name" class="block text-gray-800 font-semibold mb-2">Full Name</label>
                    <input type="text" id="name" name="fullname" class="w-full px-4 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-900 focus:outline-none focus:ring-2 focus:ring-red-500" placeholder="Enter your full name" required>
                </div>
                <div>
                    <label for="gender" class="block text-gray-800 font-semibold mb-2">Gender</label>
                    <input id="gender" name="gender" class="w-full px-4 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-900 focus:outline-none focus:ring-2 focus:ring-red-500" placeholder="Enter your gender" required>
                </div>
            </div>

            <!-- Email and Password Inputs (Two fields in one line) -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                <div>
                    <label for="email" class="block text-gray-800 font-semibold mb-2">Email Address</label>
                    <input type="email" id="email" name="email" class="w-full px-4 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-900 focus:outline-none focus:ring-2 focus:ring-red-500" placeholder="Enter your email" required>
                </div>
                <div>
                    <label for="password" class="block text-gray-800 font-semibold mb-2">Password</label>
                    <input type="password" id="password" name="password" class="w-full px-4 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-900 focus:outline-none focus:ring-2 focus:ring-red-500" placeholder="Enter your password" required>
                </div>
            </div>

            <!-- Contact Number Input -->
            <div class="mb-4">
                <label for="contactnumber" class="block text-gray-800 font-semibold mb-2">Contact Number</label>
                <input type="tel" id="contactnumber" name="contactnumber" class="w-full px-4 py-2 border border-gray-300 rounded-md bg-gray-100 text-gray-900 focus:outline-none focus:ring-2 focus:ring-red-500" placeholder="Enter your contact number" required>
            </div>

            <!-- Profile Image Upload -->
            <div class="mb-4">
                <label for="image" class="block text-gray-800 font-semibold mb-2">Upload Profile Picture</label>
                <input type="file" id="image" name="profileImage" class="w-full text-gray-900 bg-gray-100 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-red-500" accept="image/*">
            </div>

            <!-- Submit Button -->
            <div class="mt-6">
                <button type="submit" class="w-full bg-red-600 text-white font-bold py-3 px-4 rounded-lg hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 transition duration-300">
                    Register
                </button>
            </div>
        </form>
    </div>
</body>
</html>
