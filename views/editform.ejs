<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            font-family: 'Roboto', sans-serif;
        }
    </style>
</head>
<body class="bg-gray-100 flex justify-center items-center h-screen m-0 p-0">
    <div class="relative bg-white border-2 border-gray-300 rounded-2xl shadow-xl p-8 w-full max-w-lg overflow-hidden">
        <h1 class="text-blue-600 text-3xl font-bold text-center mb-8">Edit Profile</h1>
        <form action="/home/update-profile/<%= user._id %>" method="post">
            <div class="mb-6">
                <label for="fullname" class="block text-gray-700 text-lg font-semibold mb-2">Full Name</label>
                <input type="text" id="fullname" name="fullname" placeholder="Enter your full name" value="<%= userData.fullname %>" required class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg bg-gray-100 text-gray-800 placeholder-gray-500 focus:border-blue-400 focus:outline-none transition duration-300">
            </div>
            <div class="mb-6">
                <label for="contactnumber" class="block text-gray-700 text-lg font-semibold mb-2">Contact Number</label>
                <input type="tel" id="contactnumber" name="contactnumber" value="<%= userData.contactnumber %>" placeholder="Enter your contact number" required class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg bg-gray-100 text-gray-800 placeholder-gray-500 focus:border-blue-400 focus:outline-none transition duration-300">
            </div>
            <div class="mb-6">
                <label for="bio" class="block text-gray-700 text-lg font-semibold mb-2">
                    <% if (userData.usertype == "OWNER") { %>
                        Description
                    <% } else { %>
                        Bio
                    <% } %>
                </label>
                <textarea id="bio" name="bio" rows="4" placeholder="Write a short bio..." class="w-full px-4 py-2 border-2 border-gray-300 rounded-lg bg-gray-100 text-gray-800 placeholder-gray-500 focus:border-blue-400 focus:outline-none transition duration-300"><%= userData.description %></textarea>
            </div>
            <button type="submit" class="w-full bg-blue-600 text-white rounded-lg py-3 text-xl font-semibold hover:bg-blue-700 transition-transform transform hover:scale-105">
                Save Changes
            </button>
        </form>
    </div>
</body>
</html>
