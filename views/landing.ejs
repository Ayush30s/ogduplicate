<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gym Slider</title>
    <!-- Tailwind CSS CDN -->
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <!-- Swiper CSS CDN -->
    <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" />

    <style>
        /* Custom Animations */
        @keyframes slideInLeft {
            0% {
                opacity: 0;
                transform: translateX(-100%);
            }
            100% {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .slide-in-left {
            animation: slideInLeft 1s ease-out;
        }

        /* Swiper navigation buttons below the card slider */
        .swiper-button-next,
        .swiper-button-prev {
            position: relative;
            margin-top: 20px;
            width: 40px; /* Increased width for better visibility */
            height: 40px; /* Increased height for better visibility */
            color: #fff;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: red; /* Background color */
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.3); /* Shadow effect */
            opacity: 0.9;
            transition: opacity 0.3s, transform 0.3s;
        }

        .swiper-button-prev {
            margin-right: 10px;
        }

        .swiper-button-next {
            margin-left: 10px;
        }

        /* Center navigation buttons below slider */
        .swiper-nav-buttons {
            display: flex;
            justify-content: center;
            margin-top: 20px;
        }

        /* Add hover effects */
        .swiper-button-next:hover,
        .swiper-button-prev:hover {
            opacity: 1;
            transform: scale(1.1); /* Slight zoom effect on hover */
        }

        /* Responsive AI button and div */
        @media (max-width: 640px) {
            #aidiv {
                right: 2%;
            }
            #aiPage {
                width: calc(100% - 32px); /* Adjust width to fit screen with some padding */
                bottom: 10%;
            }
        }
    </style>
</head>
<body class="bg-black text-white">
    <%- include("./Partials/nav.ejs") %>

    <!-- AI Button -->
    <div id="aidiv" class="fixed bottom-4 right-4 z-50">
        <button id="ai" class="border border-white p-2 bg-red-600 text-white rounded-full shadow-md hover:bg-red-700 transition-all">Ask AI</button>
    </div>

    <div class="container mx-auto h-[100vh] overflow-hidden">
        <%- include("./Partials/alerts.ejs") %>
        <%- include("./Partials/success.ejs") %>

        <% if (allgyms.length === 0) { %>
            <h1 class="text-center my-[10%] font-bold text-4xl text-white">NO GYMS TO EXPLORE</h1>
        <% } else if (allgyms.length > 3) { %>
            <header class="bg-red-600 p-3 text-center slide-in-left mb-10 rounded-br-xl rounded-bl-xl">
                <h1 class="text-2xl font-semibold">Explore Gyms in Your Area</h1>
            </header>

            <!-- Slider main container -->
            <div class="swiper-container">
                <!-- Additional required wrapper -->
                <div class="swiper-wrapper">
                    <% allgyms?.forEach(gym => { %>
                        <!-- Each slide -->
                        <div class="swiper-slide">
                            <div class="text-sm rounded-lg mx-4">
                                <div class="bg-black border-2 border-red-600 rounded-lg overflow-hidden transition-transform transform hover:scale-105">
                                    <img src="<%= gym.profileImage %>" alt="<%= gym.gymname %>" class="object-cover w-full h-40 transition-opacity duration-500 hover:opacity-90">
                                    
                                    <div class="p-4">
                                        <h2 class="text-2xl font-bold mb-2"><%= gym.gymname.toUpperCase() %></h2>
                                        <p class="text-white mb-2"><%= gym.location %></p>
                                        <p class="text-white mb-2">Owned by: <span class="text-white"><%= gym.fullname %></span></p>
                                        <p class="text-white mb-2">Email: <span class="text-white"><%= gym.email %></span></p>
                                        <p class="text-white mb-2">Rating: <span class="text-white"><%= gym.rating %></span> / 5</p>
                                        <p class="text-sm text-white">Created on: <%= new Date(gym.createdAt).toLocaleDateString() %></p>
                                        <div class="mt-4">
                                            <a href="/home/gym/<%= gym._id %>" class="block w-full font-semibold text-center py-2 rounded-lg hover:text-white transition-all">
                                                View More
                                            </a>
                                        </div>  
                                    </div>
                                </div>
                            </div>
                        </div>                        
                    <% }) %>
                </div>
            </div>

            <!-- Navigation buttons -->
            <div class="swiper-nav-buttons">
                <div class="swiper-button-prev text-red-600 mx-20 hover:text-white"></div>
                <div class="swiper-button-next text-red-600 mx-20 hover:text-white"></div>
            </div>
        <% } else { %>
            <header class="bg-red-600 p-3 text-center slide-in-left mb-10 rounded-br-xl rounded-bl-xl">
                <h1 class="text-2xl font-bold">Explore Gyms in Your Area</h1>
            </header>

            <!-- Simple grid layout if gyms are less than or equal to 3 -->
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
                <% allgyms?.forEach(gym => { %>
                    <div class="text-sm rounded-lg mx-4">
                        <div class="bg-black border-2 border-red-600 rounded-lg overflow-hidden transition-transform transform hover:scale-105 hover:shadow-red-600/50">
                            <img src="<%= gym.profileImage %>" alt="<%= gym.gymname %>" class="object-cover w-full h-40 transition-opacity duration-500 hover:opacity-90">
                            
                            <div class="p-4">
                                <h2 class="text-2xl font-bold mb-2"><%= gym.gymname.toUpperCase() %></h2>
                                <p class="text-white mb-2"><%= gym.location %></p>
                                <p class="text-white mb-2">Owned by: <span class="text-white"><%= gym.fullname %></span></p>
                                <p class="text-white mb-2">Email: <span class="text-white"><%= gym.email %></span></p>
                                <p class="text-white mb-2">Rating: <span class="text-white"><%= gym.rating %></span> / 5</p>
                                <p class="text-sm text-white">Created on: <%= new Date(gym.createdAt).toLocaleDateString() %></p>
                                <div class="mt-4">
                                    <a href="/home/gym/<%= gym._id %>" class="block w-full font-semibold text-center py-2 rounded-lg hover:text-black hover:bg-white transition-all">
                                        View More
                                    </a>
                                </div>  
                            </div>
                        </div>
                    </div>
                <% }) %>
            </div>

            <!-- Navigation buttons -->
            <div class="swiper-nav-buttons">
                <div class="swiper-button-prev text-red-600 mx-20 hover:text-white"></div>
                <div class="swiper-button-next text-red-600 mx-20 hover:text-white"></div>
            </div>
        <% } %>
    </div>

    <!-- Swiper JS CDN -->
    <script src="https://unpkg.com/swiper/swiper-bundle.min.js"></script>

    <!-- Initialize Swiper -->
    <% if (allgyms.length > 3) { %>
        <script>
            var swiper = new Swiper('.swiper-container', {
                effect: 'coverflow',
                grabCursor: true,
                centeredSlides: true,
                slidesPerView: 'auto',
                coverflowEffect: {
                    rotate: 50,
                    stretch: 0,
                    depth: 100,
                    modifier: 1,
                    slideShadows: true,
                },
                loop: true,
                navigation: {
                    nextEl: '.swiper-button-next',
                    prevEl: '.swiper-button-prev',
                },
                breakpoints: {
                    620: {
                        slidesPerView: 1,
                        spaceBetween: 20,
                    },
                    768: {
                        slidesPerView: 2,
                        spaceBetween: 30,
                    },
                    1022: {
                        slidesPerView: 3,
                        spaceBetween: 20,
                    },
                }
            });
        </script>
    <% } %>

    <!-- AI Message Script -->
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();

        // Boolean to track visibility of AI page
        let isAIPageVisible = false;

        // Toggle the visibility of the AI message page when the AI button is clicked
        document.getElementById("ai").addEventListener("click", () => {
            const aiPage = document.getElementById("aiPage");

            if (isAIPageVisible) {
                aiPage.style.display = "none";
            } else {
                aiPage.style.display = "block";
            }
            isAIPageVisible = !isAIPageVisible;
        });

        socket.on('message', (msg) => {
            document.getElementById('message').innerHTML += `<p>${msg}</p>`;
        });
    </script>
</body>
</html>
