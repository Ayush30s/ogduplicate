<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gym Details</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <style>
        body {
            background-image: url('https://img.freepik.com/premium-photo/gym-with-red-wall-black-bench-with-red-light-it_911201-3385.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
        }

        .overlay {
            background-color: rgba(0, 0, 0, 0.7); /* Slightly transparent black overlay */
        }

        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;700;900&display=swap');

        body {
            font-family: 'Roboto', sans-serif;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .animate-fadeIn {
            animation: fadeIn 1.5s ease-in-out;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .animate-fadeInUp {
            animation: fadeInUp 1s ease-in-out;
        }

        @keyframes textGlow {
            0%, 100% { text-shadow: 0 0 10px rgba(255, 0, 0, 0.8), 0 0 20px rgba(255, 0, 0, 0.6), 0 0 30px rgba(255, 0, 0, 0.5); }
            50% { text-shadow: 0 0 20px rgba(255, 0, 0, 1), 0 0 40px rgba(255, 0, 0, 0.8), 0 0 50px rgba(255, 0, 0, 0.6); }
        }
        .animate-textGlow {
            animation: textGlow 2s ease-in-out infinite;
        }

        /* Responsive Styles */
        @media (max-width: 640px) {
            .sm:border-0 {
                border: none !important;
            }
            .sm:border-0 img {
                border: none !important;
            }
            .w-full {
                width: 100% !important;
            }
            .max-w-6xl {
                max-width: 100% !important;
            }
            .max-w-md {
                max-width: 100% !important;
            }
            .px-4 {
                padding-left: 1rem !important;
                padding-right: 1rem !important;
            }
            .py-6 {
                padding-top: 1.5rem !important;
                padding-bottom: 1.5rem !important;
            }
            .text-3xl {
                font-size: 1.875rem !important;
            }
            .text-4xl {
                font-size: 2.25rem !important;
            }
            .text-lg {
                font-size: 1.125rem !important;
            }
            .text-sm {
                font-size: 0.875rem !important;
            }
            .mb-4 {
                margin-bottom: 1rem !important;
            }
            .mb-6 {
                margin-bottom: 1.5rem !important;
            }
            .mt-10 {
                margin-top: 2.5rem !important;
            }
            .h-48 {
                height: 12rem !important;
            }
            .h-64 {
                height: 16rem !important;
            }
            .px-6 {
                padding-left: 1.5rem !important;
                padding-right: 1.5rem !important;
            }
            .py-3 {
                padding-top: 0.75rem !important;
                padding-bottom: 0.75rem !important;
            }
        }

        /* Additional Styles */
        .text-red-600 {
            color: #ef4444;
        }
    </style>
</head>
<body class="min-h-screen flex flex-col bg-black text-white font-sans">
    <!-- Navigation Bar -->
    <%- include("./Partials/nav.ejs") %>

    <% if (locals.msg == false) { %>
        <div class="m-auto inline font-bold uppercase px-6 py-4 rounded-full shadow-sm border-2 border-black transition-transform transform scale-105 bg-black text-red-600 shadow-red-600/50">
            This is a user type Email, to open a gym use another email
        </div>        
    <% } else { %>
        <!-- Main Content -->
        <div class="w-full flex-grow flex flex-col items-center justify-center px-4 sm:px-8 py-6 sm:py-12 shadow-sm shadow-white overflow-hidden">

            <!-- Gym Information Container -->
            <div class="relative bg-gray-800 p-6 sm:p-10 mb-8 border border-red-600 w-full max-w-6xl rounded-xl transform transition-transform duration-500 hover:scale-105 hover:shadow-red-700/80 flex flex-col sm:flex-row gap-6">
                <!-- Edit Profile Button -->
                <a href="/app/editprofile" class="absolute z-10 top-4 right-4 bg-gradient-to-r from-red-600 to-red-700 text-white font-bold px-4 py-2 rounded-full border border-red-500 shadow-md hover:shadow-lg transition-transform hover:scale-105 duration-300 text-sm md:text-base">
                    Edit Profile
                </a>
            
                <!-- Left Section: Gym Image -->
                <div class="w-full sm:w-1/3 relative overflow-hidden rounded-xl shadow-xl ">
                    <img src="<%= gymData.profileImage %>" alt="gym img" class="w-full h-56 sm:h-72 object-cover rounded-lg">
                </div>
            
                <!-- Right Section: Gym Details -->
                <div class="flex flex-col w-full sm:w-2/3 space-y-6">
                    <!-- Gym Name -->
                    <h2 class="text-4xl font-extrabold text-red-600 tracking-widest uppercase text-center sm:text-left">
                        <%= gymData.gymname %>
                    </h2>
            
                    <!-- Owner and Location -->
                    <div class="flex flex-col sm:flex-row sm:space-x-10 space-y-4 sm:space-y-0 text-gray-400">
                        <div class="flex flex-col w-full sm:w-1/2">
                            <p class="text-base sm:text-lg font-semibold flex items-center">
                                <span class="text-white mr-2">💼 Owned by: </span><%= gymData.fullname %>
                            </p>
                            <p class="text-base sm:text-lg font-semibold flex items-center">
                                <span class="text-white mr-2">📍 Location: </span><%= gymData.location %>
                            </p>
                        </div>
            
                        <!-- Email and Contact Number -->
                        <div class="flex flex-col w-full sm:w-1/2">
                            <p class="text-base sm:text-lg font-semibold flex items-center">
                                <span class="text-white mr-2">📞 Contact Number: </span><%= gymData.contactnumber %>
                            </p>
                            <p class="text-base sm:text-lg font-semibold flex items-center">
                                <span class="text-white mr-2">✉️ Email: </span><%= gymData.email %>
                            </p>
                        </div>
                    </div>

                    <div class="rounded-lg w-full">
                        <div class="flex flex-row my-2">
                            <a href="/request/user/followersList/<%= gymData._id %>" class="w-full px-2 md:px-4 py-2 mr-2 bg-red-600 text-center shadow-sm text-white font-bold rounded-full transition-all duration-200 hover:bg-red-700">
                                Followers: <%= followersCount %>
                            </a>
                            <a href="/request/user/followingList/<%= gymData._id %>" class="w-full px-2 md:px-4 py-2 ml-2 bg-red-600 text-center shadow-sm text-white font-bold rounded-full transition-all duration-200 hover:bg-red-700">
                                Following: <%= followingCount %>
                            </a>
                        </div>
                    </div>
            
                    <!-- Description -->
                    <div class="bg-gray-700 p-6 rounded-lg shadow-inner max-h-56 overflow-auto transition-all duration-300 hover:bg-gray-600">
                        <h3 class="text-lg sm:text-xl font-bold text-red-500 mb-2">Description</h3>
                        <p class="text-gray-300 text-sm sm:text-base font-semibold leading-relaxed text-justify">
                            <%= gymData.description %>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Cards for Shifts, Members, and Analytics -->
            <div class="flex flex-col text-sm md:p-10 sm:w-[100%] md:w-[50%] sm:p-6 w-full items-center md:justify-between gap-4 m-auto">
                <!-- Shifts Accordion -->
                <div class="w-full">
                    <div class="flex justify-between items-center space-x-4">
                        <!-- Show Shifts Button -->
                        <button id="shiftsAccordionButton" class="w-full bg-red-600 text-white uppercase px-6 py-3 rounded-full shadow-lg hover:bg-black hover:text-red-600 hover:shadow-red-600/50 border-2 border-black text-center transition-transform transform hover:scale-110 focus:outline-none focus:ring-4 focus:ring-red-600/50">
                            Show Shifts
                        </button>
                    
                        <!-- Add Shift Link -->
                        <a href="/app/edit-gym/<%= gymData._id %>" class="w-full bg-red-600 text-white uppercase px-6 py-3 rounded-full shadow-lg hover:bg-black hover:text-red-600 hover:shadow-red-600/50 border-2 border-black text-center transition-transform transform hover:scale-110 focus:outline-none focus:ring-4 focus:ring-red-600/50">
                            Add Shift
                        </a>
                    </div>
                    
                    <div id="shiftsAccordionContent" class="hidden bg-black rounded-lg p-4 mt-4 flex flex-col items-center space-y-6">
                        <!-- Visible on smaller devices -->
                        <div class="w-full flex-row justify-center items-center overflow-auto">
                            <% if (gymData.shifts.length > 0) { %>
                                <% gymData.shifts.forEach(function(shift, index) { %>
                                    <a href="/home/profile/shiftdetail/<%= gymData._id %>/<%= shift._id %>" class="w-full">
                                        <div class="w-full flex flex-col justify-between items-start align-middle my-3 p-2 bg-gray-700 rounded-lg transition-all hover:bg-red-500 hover:text-black duration-300 shadow-lg">
                                            <h4 class="font-bold text-white mb-2 hover:text-black">Timing: <%= shift.starttime %> - <%= shift.endtime %></h4>
                                            <div class="flex sm:flex-col md:flex-row">
                                                <p class="text-sm text-gray-400 mb-2 pr-2">Members: <span class="text-white hover:text-black"><%= shift.joinedby.length %></span></p>
                                                <p class="text-sm text-gray-400 mb-2 pr-2">Gender: <span class="text-white hover:text-black"><%= shift.sex %></span></p>
                                                <p class="text-sm text-gray-400 mb-2 pr-2">Limit: <span class="text-white hover:text-black"><%= shift.limit %></span></p>
                                            </div>
                                            <% if (!locals.gymIdSameUserId) { %>
                                                <a href="/home/gym/<%= gymData._id %>/join-shift/<%= shift._id %>">
                                                    <button class="absolute top-24 right-2 bg-red-600 text-white hover:text-black px-2 py-1 rounded-full text-xs font-bold uppercase transform transition-transform hover:scale-105">Join</button>
                                                </a>
                                            <% } %>
                                        </div>
                                    </a>
                                <% }); %>
                            <% } else { %>
                                <div class="w-full text-center p-6 bg-black rounded-lg shadow-lg">
                                    <h1 class="text-2xl font-bold text-red-600">No Active Shift</h1>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- Members Accordion -->
                <div class="w-full">
                    <!-- Button to Show Members -->
                    <button id="membersAccordionButton" class="w-full bg-red-600 text-white uppercase px-6 py-3 rounded-full shadow-lg hover:bg-black hover:text-red-600 hover:shadow-red-600/50 border-2 border-black text-center transition-transform transform hover:scale-105 focus:outline-none focus:ring-4 focus:ring-red-600/50">
                        Show Members
                    </button>
                
                    <!-- Members Accordion Content -->
                    <div id="membersAccordionContent" class="hidden bg-black p-4 mt-4 w-full flex flex-col items-center space-y-4">
                        <% if (gymData.joinedby.length > 0) { %>        
                            <!-- Members List -->
                            <% gymData.joinedby.forEach(function(user) { 
                                let shiftIndex = userToshiftMap.get((user.user._id).toString());
                            %>
                                <div class="w-full flex flex-row items-center p-4 bg-black rounded-lg border-2 border-red-600 transition-all duration-300 shadow-lg">
                                    <!-- Profile Image -->
                                    <a href="/home/profile/<%= user.user._id %>" class="w-[15%] h-[15%] mr-4 text-center rounded-full">
                                        <img src="<%= user.user.profileImage %>" alt="Member" class="w-10 h-10 rounded-full border-2 border-white hover:p-1 hover:border-red-600 transition-all duration-300 transform hover:scale-110">
                                    </a>
                
                                    <!-- Member Details -->
                                    <div class="flex-grow flex flex-row sm:items-center justify-between text-center sm:text-left">
                                        <!-- Member Name -->
                                        <div class="mb-2 sm:mb-0 sm:w-1/3 font-semibold">
                                            <%= user.user.fullname %>
                                        </div>
                
                                        <!-- Joined Date -->
                                        <div class="mb-2 sm:mb-0 sm:w-1/3">
                                            <%= user.user.createdAt?.toLocaleDateString() %>
                                        </div>
                
                                        <!-- Shift Info -->
                                        <div class="font-bold sm:w-1/3">
                                            <span class="bg-red-600 px-2 py-1 rounded-full text-black shadow-lg">Shift: <%= shiftIndex %></span>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                
                        <% } else { %>
                            <!-- No Members Message -->
                            <div class="w-full text-center p-6 bg-black rounded-lg shadow-lg">
                                <h1 class="text-2xl font-bold text-red-600">No Members Have Joined Yet</h1>
                            </div>
                        <% } %>
                    </div>
                </div>
                

                <!-- Analytics Toggle Button -->
                <div class="w-full flex flex-col items-center">
                    <button id="analyticsAccordionButton" class="bg-red-600 text-white uppercase px-6 py-3 rounded-full shadow-lg hover:bg-black hover:text-red-600 hover:shadow-red-600/50 border-2 border-black text-center transition-transform transform hover:scale-105 focus:outline-none focus:ring-4 focus:ring-red-600/50">
                        Show Analytics
                    </button>
                    <div id="analyticsAccordionContent" class="hidden bg-black rounded-lg p-2 mt-4 w-full flex flex-col items-center">
                        <canvas id="myChart1" width="400" height="400" class="w-full h-64 md:h-80"></canvas>
                    </div>
                </div>
            </div>
        </div>
    <% } %>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>

        const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

        // Data from the backend, replace this with your actual data
        const activeMonth = <%- JSON.stringify(locals.montharray) %>;

        const ctx1 = document.getElementById('myChart1').getContext('2d');
        new Chart(ctx1, { 
            type: 'bar',
            data: {
                labels: months, // Set months on X-axis
                datasets: [{
                    label: 'Number of Users Joined',
                    data: activeMonth, // Data for Y-axis
                    borderWidth: 1,
                    backgroundColor: [
                        '#E63946', '#F72585', '#FFB703', '#023047', '#6C757D', '#343A40', '#E63946', '#F72585', '#FFB703', '#023047', '#6C757D', '#343A40'
                    ]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                    },
                    title: {
                        display: true,
                        text: 'Monthly User Join Statistics'
                    }
                },
                scales: {
                    x: {
                        title: {
                            display: true,
                            text: 'Month'
                        }
                    },
                    y: {
                        title: {
                            display: true,
                            text: 'Number of Users'
                        },
                        beginAtZero: true
                    }
                }
            }
        });
    </script>

    <script>
        document.documentElement.style.scrollBehavior = "smooth";

        // Toggle Shifts Accordion
        document.getElementById('shiftsAccordionButton').addEventListener('click', function() {
            var content = document.getElementById('shiftsAccordionContent');
            if (content.classList.contains('hidden')) {
                content.classList.remove('hidden');
                this.textContent = 'Hide Shifts';
            } else {
                content.classList.add('hidden');
                this.textContent = 'Show Shifts';
            }
        });

        // Toggle Members Accordion
        document.getElementById('membersAccordionButton').addEventListener('click', function() {
            var content = document.getElementById('membersAccordionContent');
            if (content.classList.contains('hidden')) {
                content.classList.remove('hidden');
                this.textContent = 'Hide Members';
            } else {
                content.classList.add('hidden');
                this.textContent = 'Show Members';
            }
        });

        // Toggle Analytics Accordion
        document.getElementById('analyticsAccordionButton').addEventListener('click', function() {
            var content = document.getElementById('analyticsAccordionContent');
            if (content.classList.contains('hidden')) {
                content.classList.remove('hidden');
                this.textContent = 'Hide Analytics';
            } else {
                content.classList.add('hidden');
                this.textContent = 'Show Analytics';
            }
        });

    </script>
</body>
</html>
