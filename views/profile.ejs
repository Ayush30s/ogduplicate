<!DOCTYPE html>
<html lang="en">
<%- include("./Partials/head") %>
<body class="min-h-screen flex flex-col bg-gray-100 text-gray-800 font-sans">

    <!-- Navigation Bar -->
    <%- include("./Partials/nav.ejs") %>

    <!-- Main Content -->
    <div class="flex-grow flex items-center justify-center px-4 py-20 overflow-hidden">
        <!-- Profile Container -->
        <div class="relative bg-white p-8 shadow-xl w-full max-w-4xl rounded-lg border border-gray-300 transform transition-transform duration-500 hover:scale-105 hover:shadow-2xl animate-fadeIn flex flex-col md:flex-row items-center space-y-8 md:space-y-0 md:space-x-8">
            
            <!-- Edit Button -->
            <% if (!locals.showFollowButton) { %>
                <a href="/app/editprofile" class="absolute top-4 right-5 bg-blue-600 text-white font-bold px-4 py-2 rounded-full border border-blue-500 shadow-md hover:bg-blue-700 transition-all duration-200">
                    Edit Profile
                </a>
            <% } %>

            <!-- Profile Image -->
            <div class="w-full md:w-1/3 flex flex-col items-center">
                <div class="relative">
                    <img src="<%= userData?.profileImage %>" alt="Profile Image" class="w-40 h-40 object-cover rounded-full border-4 border-gray-300 shadow-md">
                    <div class="absolute inset-0 bg-gradient-to-t from-blue-500 via-transparent to-blue-500 opacity-75 rounded-full"></div>
                </div>
                <h1 class="text-3xl font-bold mt-4 text-gray-900"><%= userData?.fullname %></h1>
            </div>

            <!-- Profile Details -->
            <div class="w-full md:w-2/3 flex flex-col space-y-6">
                <!-- User Details -->
                <div class="space-y-2">
                    <p class="text-lg font-medium text-gray-700">Email:  <span class="text-gray-500"><%= userData?.email %></span></p>
                    <p class="text-lg font-medium text-gray-700">Contact Number:  <span class="text-gray-500"><%= userData?.contactnumber %></span></p>

                    <!-- Following, Followers, and Follow Buttons -->
                    <div class="flex flex-row justify-between space-x-1 my-4">
                        <% if (locals.showFollowButton === true) { %>
                            <form action="<%= locals.followingOrNot == 'Following' ? '/request/unfollow/user/' + userData._id : locals.followingOrNot == 'Follow' ? '/request/follow/user/' + userData._id : '/request/cancelrequest/user/' + userData._id %>" method="POST">
                                <button type="submit" class="px-2 py-2 bg-blue-600 shadow-sm text-white font-bold rounded-full hover:bg-blue-700 transition-all duration-200">
                                    <%= locals.followingOrNot %>
                                </button>
                            </form>
                        <% } %>
                        <a href="/request/user/followersList/<%= userData._id %>" class="px-2 py-2 bg-blue-600 w-1/2 text-center shadow-sm text-white font-bold rounded-full transition-all duration-200">
                            Followers: <%= followersCount %>
                        </a>
                        <a href="/request/user/followingList/<%= userData._id %>" class="px-2 py-2 bg-blue-600 w-1/2 text-center shadow-sm text-white font-bold rounded-full transition-all duration-200">
                            Following: <%= followingCount %>
                        </a>
                    </div>

                    <% if (locals.usertype == 'OWNER') { %>
                        <a href="/home/mygyms" class="block px-4 py-2 my-4 bg-blue-600 text-white font-bold rounded-md shadow-md hover:bg-blue-700 transition-all duration-200">My Gym</a>
                    <% } %>

                    <div class="p-1 bg-gray-100 border border-gray-300 rounded-md shadow-sm">
                        <p class="text-sm text-gray-600 overflow-auto py-1">
                            <% if (locals.usertype == "OWNER") { %>
                                <%= userData.description %>
                            <% } else { %>
                                <%= userData?.bio %>
                            <% } %>
                        </p>
                    </div>

                    <% if (locals.userData.usertype == "USER" && !locals.showFollowButton) { %>
                        <a href="/home/joinedgyms" class="block px-4 py-2 my-4 bg-blue-600 text-white font-bold rounded-md shadow-md hover:bg-blue-700 transition-all duration-200">Joined Gyms</a>
                    <% } %>
                </div>

            </div>
        </div>
    </div>

    <!-- Smooth Scroll Script -->
    <script>
        document.documentElement.style.scrollBehavior = "smooth";
    </script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');
        body {
            font-family: 'Roboto', sans-serif;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .animate-fadeIn {
            animation: fadeIn 1.2s ease-in-out;
        }

        /* Responsive Design */
        @media (max-width: 768px) {
            .md\:w-1\/3 {
                width: 100%;
            }
            .md\:w-2\/3 {
                width: 100%;
            }
        }

        /* Hover effects */
        .hover\:scale-105:hover {
            transform: scale(1.05);
        }

        .hover\:shadow-2xl:hover {
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
        }
    </style>
</body>
</html>
