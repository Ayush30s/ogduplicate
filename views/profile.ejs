<!DOCTYPE html>
<html lang="en">
<%- include("./Partials/head") %>
<body class="min-h-screen flex flex-col bg-white text-black font-sans">

    <!-- Navigation Bar -->
    <%- include("./Partials/nav.ejs") %>

    <!-- Main Content -->
    <div class="flex-grow flex items-center justify-center px-4 py-10 md:py-20 overflow-hidden">
        <!-- Profile Container -->
        <div class="relative bg-white p-6 md:p-5 shadow-lg w-full max-w-xl md:max-w-4xl rounded-lg border border-gray-300 transform transition-transform duration-500 hover:scale-105 hover:shadow-2xl animate-fadeIn flex flex-col md:flex-row items-center space-y-6 md:space-y-0 md:space-x-8">
            
            <!-- Edit Button -->
            <% if (!locals.showFollowButton) { %>
                <a href="/app/editprofile" class="absolute top-4 right-4 bg-red-600 text-white font-bold px-3 py-2 rounded-full border border-red-500 shadow-md hover:bg-red-700 transition-all duration-200 text-sm md:text-base">
                    Edit Profile
                </a>
            <% } %>

            <!-- Profile Image -->
            <div class="w-full md:w-1/3 flex flex-col items-center">
                <div class="relative">
                    <img src="<%= userData?.profileImage %>" alt="Profile Image" class="w-32 h-32 md:w-40 md:h-40 object-cover rounded-full border-4 border-black shadow-md">
                    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-black opacity-50 rounded-full"></div>
                </div>
                <h1 class="text-2xl md:text-3xl font-bold m-2 text-black text-center"><%= userData?.fullname %></h1>
            </div>

            <!-- Profile Details -->
            <div class="w-full md:w-2/3 flex flex-col space-y-4 md:space-y-6">
                <!-- User Details -->
                <div class="space-y-1 md:space-y-2">

                    <div class="flex flex-row my-2">
                        <a href="/request/user/followersList/<%= userData._id %>" class="w-full md:w-auto px-2 md:px-4 py-2 mr-2 bg-black text-center shadow-sm text-white font-bold rounded-full transition-all duration-200 hover:bg-red-600">
                            Followers: <%= followersCount %>
                        </a>
                        <a href="/request/user/followingList/<%= userData._id %>" class="w-full md:w-auto px-2 md:px-4 py-2 ml-2 bg-black text-center shadow-sm text-white font-bold rounded-full transition-all duration-200 hover:bg-red-600">
                            Following: <%= followingCount %>
                        </a>
                    </div>

                    <p class="text-sm md:text-[16px] font-medium font-medium text-black">Email: <span class="text-gray-700"><%= userData?.email %></span></p>
                    <p class="text-sm md:text-[16px] font-medium font-medium text-black">Contact Number: <span class="text-gray-700"><%= userData?.contactnumber %></span></p>

                    <!-- Following, Followers, and Follow Buttons -->
                    <div class="flex flex-col md:flex-row justify-start space-y-2 md:space-y-0 md:space-x-2 my-2 md:my-4">
                        <% if (locals.showFollowButton === true) { %>
                            <form action="<%= locals.followingOrNot == 'Following' ? '/request/unfollow/user/' + userData._id : locals.followingOrNot == 'Follow' ? '/request/follow/user/' + userData._id : '/request/cancelrequest/user/' + userData._id %>" method="POST" class="w-full md:w-auto">
                                <button type="submit" class="w-full md:w-auto px-4 py-2 bg-red-600 shadow-sm text-white font-bold rounded-full hover:bg-red-700 transition-all duration-200">
                                    <%= locals.followingOrNot %>
                                </button>
                            </form>
                        <% } %>
                    </div>

                    <% if (locals.usertype == 'OWNER') { %>
                        <a href="/home/mygyms" class="block px-4 py-2 my-2 bg-black text-white font-bold rounded-md shadow-md hover:bg-red-600 transition-all duration-200 text-center">
                            My Gym
                        </a>
                    <% } %>

                    <div class="p-2 border-b border-black">
                        <p class="text-xs md:text-sm text-black overflow-auto py-1">
                            <% if (locals.usertype == "OWNER") { %>
                                <%= userData.description %>
                            <% } else { %>
                                <%= userData?.bio %>
                            <% } %>
                        </p>
                    </div>

                    <% if (locals.userData.usertype == "USER" && !locals.showFollowButton) { %>
                        <a href="/home/joinedgyms" class="block px-4 py-2 my-10 md:my-2 bg-red-600 text-white font-bold rounded-full shadow-md hover:bg-red-600 transition-all duration-200 text-center">
                            Joined Gyms
                        </a>
                    <% } %>
                    
                </div>
            </div>
        </div>
    </div>

    <!-- Smooth Scroll Script -->
    <script>
        document.documentElement.style.scrollBehavior = "smooth";
    </script>                                                  

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');
        body {
            font-family: 'Roboto', sans-serif;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .animate-fadeIn {
            animation: fadeIn 1.2s ease-in-out;
        }

        /* Hover effects */
        .hover\:scale-105:hover {
            transform: scale(1.05);
        }

        .hover\:shadow-2xl:hover {
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.25);
        }
    </style>

    <script>
        // JavaScript to toggle visibility of additional details
        document.getElementById('toggleDetails').addEventListener('click', function() {
            const detailsDiv = document.getElementById('additionalDetails');
            if (detailsDiv.classList.contains('hidden')) {
                detailsDiv.classList.remove('hidden');
                this.textContent = 'Hide Details';
            } else {
                detailsDiv.classList.add('hidden');
                this.textContent = 'See All Details';
            }
        });
    </script>
</body>
</html>
