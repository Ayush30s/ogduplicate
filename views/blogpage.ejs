<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("./Partials/head") %>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> <!-- Added for responsiveness -->
    <title>Blogs page</title>
    <!-- Add Tailwind CSS CDN link -->
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@3.2.6/dist/tailwind.min.css" rel="stylesheet">
</head>

<body class="bg-cover bg-center bg-no-repeat bg-fixed" style="background-image: url('https://img.freepik.com/premium-photo/gym-with-red-wall-black-bench-with-red-light-it_911201-3385.jpg');">
    <%- include("./Partials/nav") %>
    <div class="bg-white rounded-xl flex flex-col justify-center items-center mx-auto my-6 p-4 sm:p-8 max-w-[95%] sm:max-w-[70%] animate-slide-in">
        <!-- Blog Image -->
        <div class="overflow-hidden rounded-lg w-full h-48 sm:h-64 flex justify-center animate-slide-in">
            <img src="<%= blog?.coverImage %>" alt="Blog Image" class="w-full h-full object-cover rounded-lg shadow-md hover:scale-105 transition-transform duration-500">
        </div>

        <div class="p-4 sm:p-8 flex flex-col w-full">
            <div class="flex flex-col sm:flex-row justify-between items-center mb-8 p-5 rounded-xl">
                <!-- Blog Date -->
                <h3 class="font-bold text-gray-800 animate-fade-in rounded-lg text-sm sm:text-base">
                    <span>Publisher</span> - <%= blog?.createdBy.fullname %>
                </h3>
                <!-- Blog Title -->
                <h1 class="text-3xl sm:text-xl font-bold text-gray-800 animate-fade-in"><%= blog?.title %></h1>
                <p class="text-gray-700 text-xs sm:text-sm animate-fade-in m-2">Published on <%= blog?.createdAt.toLocaleDateString() %></p>
            </div>
            <!-- Blog Content -->
            <div id="contentID" class="text-xs sm:text-sm text-gray-700 border border-gray-200 p-2 leading-relaxed animate-fade-in slide-in p-4 sm:p-5">
                <%- blog?.content %>
            </div>

            <div class="flex flex-col items-center my-2 w-full">
                <% if (locals.user) { %>
                    <div class="flex flex-row justify-between items-center">
                        <div class="rounded-2xl w-full">
                            <form class="p-3 flex flex-row justify-between items-center" id="likeform" method="post" action="/blog/like/<%= blog?._id %>">
                                <button id="likeButton" data-liked="false" class="p-1 text-[30px] w-[10%] sm:w-[6%] rounded-full transition-transform duration-150 ease-in-out">
                                    <% if (userHasLiked) { %>
                                        ❤️
                                    <% } else { %>
                                        🤍
                                    <% } %>
                                </button>
                                <span class="text-xs text-black sm:text-sm my-auto m-1 font-bold"><%= likecount %> Likes</span>
                            </form>
                        </div>
                        <div class="rounded-2xl w-full my-2">
                            <form class="p-2 sm:p-3 flex flex-row justify-between items-center" id="saveform" method="post" action="/blog/save/<%= blog?._id %>">
                                <button id="saveButton" data-saved="false" class="p-1 text-[30px] w-[15%] sm:w-[8%] rounded-full transition-transform duration-150 ease-in-out">
                                    <% if (userHasSaved) { %>
                                        🌟
                                    <% } else { %>
                                        ⭐
                                    <% } %>
                                </button>
                                <span class="text-xs text-black sm:text-sm my-auto m-1 font-bold"><%= saveCount %> saves</span>
                            </form>
                        </div>
                    </div>
                <% } else { %>
                    <h1 class="text-xs sm:text-sm animate-fade-in">Sign in to like and comment on blogs</h1>
                <% } %>

                <div class="bg-white shadow-xl p-3 my-2 rounded-lg w-full">
                    <h1 class="text-sm sm:text-lg font-bold">Comments (<%= comments.length %>)</h1>
                    <% if (locals.user) { %>
                        <form class="py-3 text-xs sm:text-sm" method="post" action="/blog/comment/<%= blog?._id %>">
                            <input type="text" id="content" name="content" class="border border-gray-200 text-black outline-none p-2 w-full rounded-sm" placeholder="Type your comment...">
                            <button type="submit" class="bg-black text-white hover:bg-red-600 border border-black my-2 py-2 px-3 rounded-sm">Add</button>
                        </form>
                    <% } %>
                    <div class="w-full max-h-[300px] overflow-auto">
                        <% locals?.comments.forEach(comment => { %>
                            <div class="my-5">
                                <span class="font-semibold text-black bg-gray-100 px-2 py-1 rounded-xl text-xs sm:text-sm"><%= comment.createdBy.fullname %></span>
                                <h1 class="text-xs text-black sm:text-sm px-2">🚀<%= comment.content %></h1>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Handle like button functionality
            const likeButton = document.getElementById('likeButton');
            likeButton.addEventListener('click', () => {
                const isLiked = likeButton.getAttribute('data-liked') === 'true';
                if (isLiked) {
                    likeButton.innerHTML = '🤍'; // Unliked state
                    likeButton.setAttribute('data-liked', 'false');
                } else {
                    likeButton.innerHTML = '❤️'; // Liked state
                    likeButton.setAttribute('data-liked', 'true');
                }
            });

            // Handle save button functionality
            const saveButton = document.getElementById('saveButton');
            saveButton.addEventListener('click', () => {
                const isSaved = saveButton.getAttribute('data-saved') === 'true';
                if (isSaved) {
                    saveButton.innerHTML = '⭐'; // Unsaved state
                    saveButton.setAttribute('data-saved', 'false');
                } else {
                    saveButton.innerHTML = '🌟'; // Saved state
                    saveButton.setAttribute('data-saved', 'true');
                }
            });
        });

        // Toggle dropdown menu
        document.getElementById('dropdownButton').addEventListener('click', () => {
            const dropdownMenu = document.getElementById('dropdownMenu');
            dropdownMenu.classList.toggle('hidden');
        });
    </script>
</body>

</html>
