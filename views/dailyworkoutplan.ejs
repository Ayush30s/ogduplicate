<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personalized Workout Plan</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            background-image: url('https://img.freepik.com/premium-photo/gym-with-red-wall-black-bench-with-red-light-it_911201-3385.jpg');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-attachment: fixed;
        }

        .overlay {
            background-color: rgba(0, 0, 0, 0.7); /* Slightly transparent black overlay */
        }
        @keyframes fadeInUp {
            0% {
                opacity: 0;
                transform: translateY(20px);
            }
            100% {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .fade-in-up {
            animation: fadeInUp 1s ease-out;
        }
        
        @keyframes bounceIn {
            0% {
                transform: scale(0.95);
                opacity: 0;
            }
            70% {
                transform: scale(1.05);
                opacity: 1;
            }
            100% {
                transform: scale(1);
            }
        }
        
        .bounce-in {
            animation: bounceIn 0.6s ease-in-out;
        }

        .card {
            background: #2d2d2d; /* Dark background for cards */
            border-radius: 1rem;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

        .card:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 12px rgba(0, 0, 0, 0.2);
        }

        .card-content {
            padding: 1.5rem;
            color: #ffffff;
        }

        .card-container {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .exercise-link {
            color: #1d4ed8; /* Blue color for links */
            text-decoration: underline;
        }
        
        .exercise-link:hover {
            color: #2563eb; /* Darker blue on hover */
        }
    </style>
</head>
<body class="bg-black text-white font-sans">
    <%- include("./Partials/nav.ejs") %>

    <div class="container mx-auto p-4 flex flex-col justify-center items-center">
        <h1 class="text-4xl font-extrabold mb-8 text-red-600 text-center fade-in-up">
            Personalized Workout Plan
        </h1>

        <div class="mb-8 p-6 bg-white rounded-lg shadow-lg text-gray-900">
            <h2 class="text-3xl font-semibold mb-4 text-red-600 fade-in-up">
                Additional Notes
            </h2>
            <ul class="list-disc list-inside">
                <% workoutPlan.additionalNotes.forEach(function(note, noteIndex) { %>
                    <li class="mb-2 fade-in-up">
                        <span><%= note %></span>
                    </li>
                <% }) %>
            </ul>
        </div>

        <!-- Workout Days List -->
        <div class="card-container flex sm:flex-col md:flex-row">
            <% workoutPlan.workoutDays.forEach(function(day, index) { %>
                <a href="/home/workout-day/<%= index+1 %>" class="block">
                    <div class="card p-4 bg-gray-800 text-white rounded-lg hover:bg-gray-700 transition-colors duration-300">
                        <div class="card-content">
                            <h2 class="text-2xl font-semibold mb-2 text-red-500"><%= day.day %></h2>
                            <p class="text-lg"><%= day.focus %></p>
                            <p class="mt-4">Click to see exercises</p>
                        </div>
                    </div>
                </a>
            <% }) %>
        </div>
    </div>
</body>
</html>
