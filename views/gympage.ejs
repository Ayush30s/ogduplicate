<!DOCTYPE html>
<html lang="en">
<%- include("./Partials/head") %>
<head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
</head>
<style>
    body {
        background-image: url('https://img.freepik.com/premium-photo/gym-with-red-wall-black-bench-with-red-light-it_911201-3385.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        background-attachment: fixed;
        font-family: 'Roboto', sans-serif;
    }

    .overlay {
        background-color: rgba(0, 0, 0, 0.7); /* Slightly transparent black overlay */
    }

    .text-shadow {
        text-shadow: 2px 2px 10px rgba(0, 0, 0, 0.7);
    }

    .hover-scale {
        transition: transform 0.3s ease-in-out;
    }

    .hover-scale:hover {
        transform: scale(1.05);
    }

    .animate-fadeIn {
        animation: fadeIn 1.5s ease-in-out;
    }

    @keyframes fadeIn {
        0% {
            opacity: 0;
            transform: translateY(30px);
        }
        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .card {
        background-color: rgba(0, 0, 0, 0.85);
        border-radius: 15px;
        padding: 20px;
        box-shadow: 0px 15px 20px rgba(0, 0, 0, 0.3);
        transition: all 0.3s ease;
    }

    .card:hover {
        box-shadow: 0px 25px 30px rgba(0, 0, 0, 0.5);
    }

    .rating-stars {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 0.6rem;
        transition: all 0.3s ease;
    }

    .rating-stars button {
        font-size: 2rem;
        color: gray;
        transition: transform 0.3s ease, color 0.3s ease;
    }

    .rating-stars button:hover,
    .rating-stars button:hover ~ button {
        transform: scale(1.2);
        color: gold;
    }

    .active-star {
        color: gold;
        transform: scale(1.2);
    }

    #submitRating {
        background-color: #FF5733;
        color: white;
        border-radius: 25px;
        padding: 10px 25px;
        font-weight: 600;
        transition: background-color 0.3s ease;
    }

    #submitRating:hover {
        background-color: white;
        color: #FF5733;
        box-shadow: 0 0 15px rgba(255, 87, 51, 0.7);
    }

    /* Make elements responsive */
    @media (max-width: 768px) {
        .card {
            padding: 15px;
        }

        .text-shadow {
            font-size: 1.25rem; /* Smaller fonts for smaller screens */
        }

        .rating-stars button {
            font-size: 1.5rem; /* Smaller stars on smaller screens */
        }

        #submitRating {
            padding: 8px 20px; /* Adjust button padding */
        }
    }
</style>

<body class="min-h-screen flex flex-col bg-black text-white font-sans">

    <!-- Navigation Bar -->
    <%- include("./Partials/nav.ejs") %>
    <%- include("./Partials/success.ejs") %>
    <%- include("./Partials/alerts.ejs") %>

    <!-- Main Content -->
    <div class="flex-grow flex items-center justify-center px-6 py-10 overflow-hidden animate-fadeIn">

        <!-- Gym Information Container -->
        <div class="card w-full max-w-6xl p-6 md:p-12 flex flex-col sm:space-y-8 hover-scale space-y-12"> <!-- Added space-y-12 for spacing -->

            <!-- Gym Name -->
            <h2 class="text-4xl md:text-5xl font-bold text-red-600 tracking-wide uppercase text-center text-shadow py-5">
                <%= gymData.gymname %>
            </h2>

            <!-- Main Content Section -->
            <div class="flex flex-col md:flex-row justify-center items-center md:space-x-6 w-full space-y-8 md:space-y-0"> <!-- Added space-y-8 for vertical spacing on mobile -->
                <!-- Left Section: Gym Image and Join Button -->
                <div class="flex flex-col items-center space-y-6 w-full md:w-1/3">
                    <div class="relative w-full">
                        <img src="<%= gymData.profileImage %>" alt="<%= gymData.gymname %>" class="w-full h-auto sm:h-64 object-cover rounded-lg shadow-lg hover-scale border-4 border-red-600">
                    </div>
                    <% if (locals?.flag) { %>
                        <a href="/home/<%= gymData._id %>/leavegym" class="bg-red-600 text-white uppercase px-6 py-3 rounded-full shadow-lg hover:bg-black hover:text-red-600 transition-transform hover-scale mt-4"> <!-- Added mt-4 for margin-top -->
                            Leave
                        </a>
                    <% } else { %>
                        <a href="/home/<%= gymData._id %>/joingym" class="bg-red-600 text-white uppercase px-6 py-3 rounded-full shadow-lg hover:bg-black hover:text-red-600 transition-transform hover-scale mt-4"> <!-- Added mt-4 for margin-top -->
                            Join
                        </a>
                    <% } %>
                </div>

                <!-- Right Section: Gym Details and Description -->
                <div class="flex flex-col w-full md:w-2/3 space-y-6">
                    <div class="flex justify-between">
                        <span class="text-lg font-medium text-white shadow-inner shadow-red-500 px-4 py-3 rounded-lg inline-block">
                            Members: <%= locals.gymData.joinedby.length %>
                        </span>
                        <% if (locals.flag) { %>
                            <span class="font-medium text-white shadow-inner shadow-red-500 px-4 py-3 rounded-lg inline-block">
                                Days left to Month: <%= locals.daysLeftToMonth || 0 %>
                            </span>
                        <% } %>
                    </div>

                    <!-- Owner and Location -->
                    <div class="bg-gray-900 p-6 rounded-lg shadow-inner shadow-lg space-y-2"> <!-- Added space-y-4 for spacing -->
                        <p class="text-gray-400">Owned by: <span class="text-white"><%= gymData.fullname %></span></p>
                        <p class="text-gray-400">Location: <span class="text-white"><%= gymData.location %></span></p>
                        <p class="text-gray-400">Contact Number: <span class="text-white"><%= gymData.contactnumber %></span></p>
                        <p class="text-gray-400">Email: <span class="text-white"><%= gymData.email %></span></p>
                    </div>

                    <!-- Description -->
                    <div class="bg-gray-900 p-6 rounded-lg shadow-inner shadow-lg max-h-48 overflow-y-auto mt-6"> <!-- Added mt-6 for margin-top -->
                        <p class="text-gray-300 leading-relaxed"><strong>Description</strong> : <%= gymData.description %></p>
                    </div>
                </div>
            </div>

            <!-- Rating Form -->
            <% if (locals.flag) { %>
                <div class="text-center bg-gray-900 py-6 rounded-lg shadow-lg"> <!-- Added mt-10 for margin-top -->
                    <h3 class="text-2xl font-bold text-red-600 mb-4">Rate this Gym:</h3>
                    <div id="stars" class="rating-stars mt-2 mb-5"></div>
                    <form id="ratingForm" action="/home/rating/<%= gymData._id %>" method="POST">
                        <input type="hidden" name="rating" id="ratingInput" value="0">
                        <button type="submit" id="submitRating">Submit Rating</button>
                    </form>
                </div>
            <% } %>
        </div>
    </div>

    <!-- JavaScript for Star Rating -->
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const ratingDiv = document.getElementById("stars");
            const ratingInput = document.getElementById("ratingInput");
            let rating = 0; // Initialize rating
    
            // Create stars dynamically
            for (let i = 0; i < 5; i++) {
                const star = document.createElement('button');
                star.innerText = '⭐';
                star.className = 'text-gray-400 text-xl'; // Initially unfilled star
                star.dataset.value = i + 1;
                star.addEventListener('click', (e) => {
                    e.preventDefault(); // Prevent form submission when selecting stars
                    rating = star.dataset.value;
                    updateStars();
                    updateRatingInput(); // Update the hidden input value
                });
                ratingDiv.appendChild(star);
            }
    
            // Update stars based on the current rating
            function updateStars() {
                const stars = ratingDiv.querySelectorAll('button');
                stars.forEach(star => {
                    if (star.dataset.value <= rating) {
                        star.innerText = '🌟'; // Change to filled star
                        star.classList.add('text-yellow-600');
                        star.classList.remove('text-gray-400');
                    } else {
                        star.innerText = '⭐'; // Change to unfilled star
                        star.classList.add('text-gray-400');
                        star.classList.remove('text-yellow-600');
                    }
                });
            }
    
            // Update the hidden input value
            function updateRatingInput() {
                ratingInput.value = rating; // Update the hidden form input with the rating
            }
        });
    </script>
</body>
</html>
