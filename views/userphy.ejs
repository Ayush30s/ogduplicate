<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Personalized Workout Plan Form</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-black text-white">

    <div class="flex justify-center items-center min-h-screen">
        <form action="/register/addmoredetails" method="POST" class="bg-gray-900 p-8 rounded-lg shadow-lg w-full max-w-lg">
            <h1 class="text-2xl font-bold mb-6 text-center text-red-500">Personalized Workout Plan</h1>

            <div class="mb-4">
                <label for="height" class="block mb-2 text-white">Height (cm)</label>
                <input type="number" id="height" name="height" class="w-full px-3 py-2 bg-gray-800 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
            </div>

            <div class="mb-4">
                <label for="weight" class="block mb-2 text-white">Weight (kg)</label>
                <input type="number" id="weight" name="weight" class="w-full px-3 py-2 bg-gray-800 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
            </div>

            <div class="mb-4">
                <label for="fitnessGoal" class="block mb-2 text-white">Fitness Goal</label>
                <select id="fitnessGoal" name="fitnessGoal" class="w-full px-3 py-2 bg-gray-800 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
                    <option value="muscleGain">Muscle Gain</option>
                    <option value="weightLoss">Weight Loss</option>
                    <option value="endurance">Endurance</option>
                </select>
            </div>

            <div class="mb-4">
                <label for="experienceLevel" class="block mb-2 text-white">Experience Level</label>
                <select id="experienceLevel" name="experienceLevel" class="w-full px-3 py-2 bg-gray-800 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
                    <option value="beginner">Beginner</option>
                    <option value="intermediate">Intermediate</option>
                    <option value="advanced">Advanced</option>
                </select>
            </div>

            <div class="mb-4">
                <label for="availableEquipment" class="block mb-2 text-white">Available Equipment</label>
                <input type="text" id="availableEquipment" name="availableEquipment" placeholder="e.g., Dumbbells, Barbell" class="w-full px-3 py-2 bg-gray-800 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
            </div>

            <div class="mb-4">
                <label for="workoutFrequency" class="block mb-2 text-white">Workout Frequency (days per week)</label>
                <input type="number" id="workoutFrequency" name="workoutFrequency" min="1" max="7" class="w-full px-3 py-2 bg-gray-800 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
            </div>

            <div class="mb-6">
                <label for="injuriesLimitations" class="block mb-2 text-white">Injuries or Limitations</label>
                <textarea id="injuriesLimitations" name="injuriesLimitations" rows="3" class="w-full px-3 py-2 bg-gray-800 text-white rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500" placeholder="Please describe any injuries or limitations"></textarea>
            </div>

            <div class="text-center">
                <button type="submit" class="w-full py-3 bg-red-500 text-white rounded-lg hover:bg-red-600 focus:outline-none focus:ring-2 focus:ring-red-700">Submit</button>
            </div>
        </form>
    </div>

</body>
</html>
