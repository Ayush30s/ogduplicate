<!DOCTYPE html>
<html lang="en">
    <title>GymApp</title>
<%- include("./Partials/head") %>
<body class="bg-gray-100 text-gray-800">
    <section class="bg-cover bg-center h-screen" style="background-image: url('https://images.unsplash.com/photo-1515162305283-7d58b244eb7e');">
        <div class="flex flex-col items-center justify-center h-full bg-white bg-opacity-80 p-4 sm:p-8">
            <div class="text-center mb-6 w-full max-w-lg">
                <%- include("./Partials/alerts.ejs") %>
            </div>
            <div class="text-center w-full max-w-lg">
                <h1 class="text-3xl sm:text-5xl font-bold text-blue-600">Welcome to GymApp</h1>
                <p class="text-lg sm:text-xl text-gray-600 mt-4">Achieve your fitness goals with us</p>
                <div class="mt-6 space-y-4 sm:space-y-0 sm:space-x-4 sm:flex sm:justify-center">
                    <a href="/app/register-user" class="inline-block bg-blue-600 text-white font-bold py-3 px-6 rounded-full hover:bg-blue-700 transition-all">
                        Register
                    </a>
                    <a href="/app/signin-form" class="inline-block bg-blue-600 text-white font-bold py-3 px-6 rounded-full hover:bg-blue-700 transition-all">
                        Already have an account? Sign in
                    </a>
                </div>
            </div>
        </div>
    </section>
</body>
</html>
