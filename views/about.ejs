<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>About Us - GymApp</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css" rel="stylesheet">
    <style>
        
        /* Custom Animations */
        @keyframes slideInLeft {
            0% {
                opacity: 0;
                transform: translateX(-100%);
            }
            100% {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @keyframes fadeIn {
            0% {
                opacity: 0;
            }
            100% {
                opacity: 1;
            }
        }

        .slide-in-left {
            animation: slideInLeft 1s ease-out;
        }

        .fade-in {
            animation: fadeIn 2s ease-in-out;
        }
    </style>
</head>
<body class="bg-gray-100 text-gray-800 font-sans">
    <%- include("./Partials/nav") %>

    <!-- Header Section -->
    <header class="bg-blue-600 p-6 text-center slide-in-left">
        <h1 class="text-4xl font-bold text-white">About GymApp</h1>
        <p class="text-lg mt-2 text-white">Your Ultimate Fitness Companion</p>
    </header>

    <!-- Main Content Section -->
    <main class="container mx-auto p-6">
        <!-- Mission Section -->
        <section class="fade-in my-10">
            <h2 class="text-3xl font-semibold text-blue-600 mb-4">Our Mission</h2>
            <p class="text-lg leading-relaxed">
                At GymApp, our mission is to empower individuals to achieve their fitness goals with the support of
                cutting-edge technology. Whether you're a seasoned athlete or just starting your fitness journey, GymApp
                provides personalized workouts, nutrition plans, and real-time progress tracking to keep you motivated
                and on track.
            </p>
        </section>

        <!-- Features Section -->
        <section class="my-10">
            <h2 class="text-3xl font-semibold text-blue-600 mb-4 slide-in-left">Why Choose GymApp?</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="bg-blue-600 p-6 rounded-lg text-white hover:scale-105 transform transition-transform duration-300 ease-in-out">
                    <h3 class="text-xl font-bold">Personalized Plans</h3>
                    <p class="mt-2">
                        Tailored workout and nutrition plans to suit your unique needs and goals.
                    </p>
                </div>
                <div class="bg-blue-600 p-6 rounded-lg text-white hover:scale-105 transform transition-transform duration-300 ease-in-out">
                    <h3 class="text-xl font-bold">Real-Time Tracking</h3>
                    <p class="mt-2">
                        Monitor your progress with our advanced tracking features, ensuring you stay on course.
                    </p>
                </div>
                <div class="bg-blue-600 p-6 rounded-lg text-white hover:scale-105 transform transition-transform duration-300 ease-in-out">
                    <h3 class="text-xl font-bold">Community Support</h3>
                    <p class="mt-2">
                        Join a vibrant community of fitness enthusiasts to stay motivated and share your journey.
                    </p>
                </div>
            </div>
        </section>

        <!-- Call to Action Section -->
        <section class="text-center my-20">
            <h2 class="text-4xl font-bold text-blue-600 mb-6 fade-in">Join Us Today!</h2>
            <p class="text-lg mb-6 fade-in">
                Ready to transform your life? Download GymApp now and start your fitness journey with us!
            </p>
            <a href="/home" class="bg-gray-800 text-white px-8 py-4 rounded-full font-bold text-lg transition-colors duration-300 hover:bg-blue-600">
                Get Started
            </a>
        </section>
    </main>

    <!-- Footer Section -->
    <footer class="bg-gray-800 p-6 text-center fade-in">
        <p class="text-gray-300">© 2024 GymApp. All rights reserved.</p>
    </footer>

</body>
</html>
