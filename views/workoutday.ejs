<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Workout Plan</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@3.2.0/dist/tailwind.min.css" rel="stylesheet">
    <style>
        /* Simple Background */
        body {
            background-color: #f9fafb; /* Light grey background */
            display: flex;
            justify-content: center;
            padding: 20px;
            margin: 0;
            font-family: sans-serif;
        }

        /* Container */
        .container {
            max-width: 800px;
            width: 100%;
        }

        /* Simple Card Styling */
        .card {
            background-color: #ffffff; /* White card */
            border: 1px solid #e5e7eb; /* Light border */
            border-radius: 0.5rem;
            padding: 1rem;
            margin-bottom: 1rem;
            transition: transform 0.2s ease-in-out;
            text-decoration: none; /* Remove underline */
            color: #111827; /* Default text color */
        }

        .card:hover {
            transform: translateY(-5px); /* Slight lift on hover */
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1); /* Add shadow on hover */
        }

        /* Typography */
        h1 {
            color: #111827; /* Darker heading */
            font-size: 1.5rem;
            margin-bottom: 1.5rem;
            text-align: center;
        }

        h2 {
            color: #111827; /* Darker subheading */
            font-size: 1.25rem;
            margin-bottom: 0.5rem;
        }

        p {
            color: #374151; /* Dark grey text */
            margin-bottom: 0.25rem;
        }

        /* Responsive Layout */
        .grid {
            display: grid;
            gap: 1rem;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        }
    </style>
</head>

<body>

    <div class="container">
        <h1><%= workoutDays.day %>: <%= workoutDays.focus %> Workout</h1>

        <div class="grid">
            <% workoutDays.exercises.forEach(exercise => { %>
                <a href="/home/workout-day/2/:<%= exercise.name %>" class="card">
                    <h2><%= exercise.name %></h2>
                    <p><strong>Sets:</strong> <%= exercise.sets %></p>
                    <p><strong>Reps:</strong> <%= exercise.reps %></p>
                    <p><strong>Focus:</strong> <%= exercise.focus %></p>
                </a>
            <% }) %>
        </div>
    </div>

</body>

</html>
