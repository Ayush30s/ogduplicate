<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Workout Plan</title>
    <link href="https://cdn.jsdelivr.net/npm/tailwindcss@3.2.0/dist/tailwind.min.css" rel="stylesheet">
    <style>
        /* Dark Background */
        body {
            background-color: #111827; /* Dark grey background */
            display: flex;
            justify-content: center;
            padding: 20px;
            margin: 0;
            font-family: 'Inter', sans-serif;
        }

        /* Container */
        .container {
            max-width: 800px;
            width: 100%;
        }

        /* Card Styling with Black, White, and Red Theme */
        .card {
            background-color: #1f2937; /* Dark background for cards */
            border: 1px solid #ef4444; /* Red border */
            border-radius: 0.5rem;
            padding: 1.5rem;
            margin-bottom: 1rem;
            transition: transform 0.2s ease-in-out, box-shadow 0.2s;
            text-decoration: none; /* Remove underline */
            color: #f9fafb; /* White text */
        }

        .card:hover {
            transform: translateY(-5px); /* Slight lift on hover */
            box-shadow: 0 8px 16px rgba(239, 68, 68, 0.4); /* Red shadow on hover */
        }

        /* Typography */
        h1 {
            color: #f9fafb; /* White heading */
            font-size: 2rem;
            margin-bottom: 2rem;
            text-align: center;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        h2 {
            color: #ef4444; /* Red subheading */
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }

        p {
            color: #d1d5db; /* Light grey text */
            margin-bottom: 0.25rem;
        }

        /* Responsive Grid Layout */
        .grid {
            display: grid;
            gap: 1.5rem;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        }

        /* Card hover effect */
        .card:hover h2 {
            color: #ffffff; /* Turn subheading white on hover */
        }

        /* Card hover effect for text */
        .card:hover p {
            color: #f3f4f6; /* Slightly lighter text on hover */
        }
    </style>
</head>

<body>

    <div class="container">
        <h1><%= day %>: <%= workoutDays.focus %> Workout</h1>
        <div class="grid">
            <% workoutDays.exercises.forEach((exercise, index) => { %>
                <a href="/home/workout-day/<%=day%>/workout/<%= index %>/<%= exercise.name %>" class="card">
                    <h2><%= exercise.name %></h2>
                    <p><strong>Sets:</strong> <%= exercise.sets %></p>
                    <p><strong>Reps:</strong> <%= exercise.reps %></p>
                    <p><strong>Focus:</strong> <%= exercise.focus %></p>
                </a>
            <% }) %>
        </div>
    </div>

</body>

</html>
